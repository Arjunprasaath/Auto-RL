# AutoRL Environment Variables
# Copy this file to .env and fill in your keys

# Weights & Biases
WANDB_API_KEY=
# Your W&B username or team name — used for report URLs and Weave links
WANDB_ENTITY=

# Optional: disable W&B charts only (Weave tracing still works)
# WANDB_DISABLED=1
# Optional: disable Weave tracing only (W&B charts still work)
# WEAVE_DISABLED=1

# OpenAI (for the Orchestrator agent, OpenAI Agents SDK)
OPENAI_API_KEY=
# Optional: override the orchestrator model (default: gpt-4o-mini)
OPENAI_MODEL=

# RunPod (for cloud GPU training)
RUNPOD_API_KEY=
# Optional: reuse an existing pod instead of creating one (avoids GPU capacity errors)
# RUNPOD_POD_ID=
# Optional: force a specific GPU type, e.g. "NVIDIA GeForce RTX 3090"
# RUNPOD_GPU_TYPE=
# Optional: path to SSH private key (default: ~/.runpod/ssh or ~/.ssh/id_ed25519)
# RUNPOD_SSH_KEY_PATH=

# Weave project name
WEAVE_PROJECT=autorl

# Redis — real-time pub/sub coordination (heartbeats, nudges, run state)
# Format: redis://[[username:]password@]host[:port][/db]
# Optional: file-based fallback is used automatically when this is not set.
REDIS_URL=redis://default:MAf6HASzkqUBsKQtYt7QH03AxQrt2p9J@turbosoft-writing-lamp-88743.db.redis.io:11444

# UI — Next.js frontend (read from this file via next.config.ts)
# URL of the Python FastAPI backend (default: http://localhost:8000)
AUTORL_BACKEND_URL=http://localhost:8000
