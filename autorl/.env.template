# AutoRL Environment Variables
# Copy this file to .env and fill in your keys

# Weights & Biases
WANDB_API_KEY=

# OpenAI (for the Orchestrator agent, OpenAI Agents SDK)
OPENAI_API_KEY=
# Optional: override the orchestrator model (default: gpt-4o-mini)
OPENAI_MODEL=

# Anthropic (for Evaluator LLM calls)
ANTHROPIC_API_KEY=

# RunPod (for cloud GPU training)
RUNPOD_API_KEY=

# Weave project name
WEAVE_PROJECT=autorl
